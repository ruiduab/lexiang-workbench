const MOON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>';
function isDark(){ return document.documentElement.getAttribute('data-theme') === 'dark'; }
function applyTheme(dark){
  document.documentElement.setAttribute('data-theme', dark ? 'dark' : '');
  document.getElementById('landThemeBtn').innerHTML = dark ? MOON : SUN;
  const ctb = document.getElementById('chatThemeBtn');
  if (ctb) {
    const label = ctb.querySelector('#themeToggleLabel')?.textContent || I18N[currentLang]?.themeToggle || '切换主题';
    ctb.innerHTML = (dark ? MOON : SUN) + `<span id="themeToggleLabel">${label}</span>`;
  }
}
