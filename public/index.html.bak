<script>
// ══════════════════════════════════════
//  持久 Session UID
//  localStorage + 1年 cookie 双保险
//  清缓存不影响，只有手动清 cookie 才重置
// ══════════════════════════════════════
const _UID = (() => {
  const KEY = 'lexiang-uid';
  const readCookie = () => { const m = document.cookie.match(/(?:^|;\s*)lexiang-uid=([^;]+)/); return m ? m[1] : null; };
  const writeCookie = (v) => { document.cookie = `${KEY}=${v}; max-age=${365*24*3600}; path=/; SameSite=Lax`; };
  let uid = null;
  try { uid = localStorage.getItem(KEY); } catch(_) {}
  if (!uid) uid = readCookie();
  if (!uid) uid = 'u-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 9);
  try { localStorage.setItem(KEY, uid); } catch(_) {}
  writeCookie(uid);
  return uid;
})();

function apiFetch(url, options = {}) {
  options.headers = Object.assign({ 'x-session-id': _UID }, options.headers || {});
  return fetch(url, options);
}

// ══════════════════════════════════════
//  前端日志 & 错误上报 (Telemetry)
// ══════════════════════════════════════
const _log = {
  _send(payload){
    try{ navigator.sendBeacon('/api/log', new Blob([JSON.stringify(payload)], {type:'application/json'})); }catch(_){}
  },
  error(message, stack, extra){
    console.error('[FE]', message, extra || '');
    this._send({ type:'error', message, stack, url: location.href, extra });
  },
  apiError(url, status, message){
    console.warn('[API]', status, url, message);
    this._send({ type:'api_error', message: `${status} ${url}: ${message}`, url: location.href });
  },
  event(name, data){
    this._send({ type:'event', message: name, url: location.href, extra: data });
  }
};
window.addEventListener('error', e => {
  _log.error(e.message, e.error?.stack, { file: e.filename, line: e.lineno });
});
window.addEventListener('unhandledrejection', e => {
  _log.error('UnhandledRejection: ' + (e.reason?.message || String(e.reason)), e.reason?.stack);
});

