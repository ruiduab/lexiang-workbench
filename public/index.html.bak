async function loadConv(id){
  convId = id;
  history.pushState(null, '', '/chat/' + id);
  updateSidebar();
  const msgs = await apiFetch('/api/chat/history/' + id).then(r=>r.json()).catch(e => {
    _log.error('loadConv history fetch failed', e.stack, { convId: id });
    return [];
  });
  const inner = document.getElementById('msgsInner');
  document.querySelectorAll('.suggestions').forEach(el => el.remove());
  inner.innerHTML = '';
  msgs.forEach(m => appendBubble(m.role === 'user' ? 'user' : 'ai', m.content, true));
  scrollBottom();
  const conv = convList.find(c => c.id === id);
  if (conv) updateTitle(conv.title);
  document.getElementById('landingPage').classList.add('exit');
  document.getElementById('chatApp').classList.add('active');
  setTimeout(() => document.getElementById('mainTa').focus(), 100);
}

// ── Append message bubble ──
function appendBubble(role, text, renderMd=false){
  const ws = document.getElementById('welcomeScreen');
  if (ws) ws.remove();
  const inner = document.getElementById('msgsInner');
  const d = document.createElement('div');
  d.className = 'msg ' + role;
  const content = (renderMd && role === 'ai' && typeof marked !== 'undefined')
    ? marked.parse(text).replace(/<table/g,'<div class="table-wrap"><table').replace(/<\/table>/g,'</table></div>')
    : escHtml(text);
  if (role === 'ai') {
    const body = document.createElement('div');
    body.className = 'msg-body';
    body.innerHTML = `<div class="msg-pre"></div><div class="mbubble">${content}</div>`;
    const actions = document.createElement('div');
    actions.className = 'msg-actions';
    actions.innerHTML = `
      <button class="act-btn" onclick="copyMsg(this)"><svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>复制</button>
      <button class="act-btn fb-like" onclick="sendFeedback(this,1)" title="回答有帮助"><svg viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/><path d="M7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>有用</button>
      <button class="act-btn fb-dislike" onclick="sendFeedback(this,-1)" title="回答有问题"><svg viewBox="0 0 24 24"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/></svg>没用</button>`;
    body.appendChild(actions);
    d.innerHTML = `<div class="mavatar">乐</div>`;
    d.appendChild(body);
  } else {
    d.innerHTML = `<div class="mavatar">你</div><div class="mbubble">${content}</div>`;
  }
  inner.appendChild(d);
  scrollBottom();
  return d;
}

// ── Markdown render helper ──
function renderMdText(text) {
  if (typeof marked === 'undefined') return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  return marked.parse(text)
    .replace(/<table/g,'<div class="table-wrap"><table')
    .replace(/<\/table>/g,'</table></div>');
}

// ── Real-time streaming render ──
function startStream(el) {
  const bubble = el.querySelector('.mbubble');
  bubble.classList.add('streaming');
  bubble.innerHTML = '';
  let accumulated = '';
  let renderTimer = null;

  function scheduleRender() {
    if (renderTimer) return;
    renderTimer = setTimeout(() => {
      renderTimer = null;
      bubble.innerHTML = renderMdText(accumulated);
      scrollBottom();
    }, 80); // 80ms 节流渲染，避免频繁重排
  }

  return {
    push(chunk) {
      accumulated += chunk;
      scheduleRender();
    },
    finish() {
      if (renderTimer) { clearTimeout(renderTimer); renderTimer = null; }
      bubble.classList.remove('streaming');
      bubble.innerHTML = renderMdText(accumulated);
      scrollBottom();
      return accumulated;
    }
  };
}

// ── Typing indicator ──
let typingEl = null;
function showTyping(){
  const ws = document.getElementById('welcomeScreen');
