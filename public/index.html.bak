// ── Tool display names ──
const TOOL_DISPLAY = {
  knowledge_rag: { label: '精准检索知识库', labelEn: 'Deep knowledge search' },
  web_search:    { label: '联网搜索',       labelEn: 'Web search' },
};
function toolLabel(name) {
  const d = TOOL_DISPLAY[name];
  return d ? (currentLang === 'en' ? d.labelEn : d.label) : name;
}

// ── Process card helpers ──
function createProcessCard() {
  const el = document.createElement('div');
  el.className = 'process-card';
  el.innerHTML = `<div class="process-header" onclick="this.closest('.process-card').classList.toggle('collapsed')">
    <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
    <span class="process-title">${currentLang === 'en' ? 'Processing…' : '正在处理…'}</span>
    <svg viewBox="0 0 24 24" style="width:11px;height:11px;opacity:.5"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
  <div class="process-steps"></div>`;
  return el;
}

function addProcessStep(card, id, label) {
  const steps = card.querySelector('.process-steps');
  const s = document.createElement('div');
  s.className = 'process-step running';
  s.id = 'ps-' + id;
  s.innerHTML = `<svg viewBox="0 0 24 24"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg><span>${label}</span>`;
  steps.appendChild(s);
  scrollBottom();
}

function doneProcessStep(card, id, success = true) {
  const s = document.getElementById('ps-' + id);
  if (!s) return;
  s.className = 'process-step ' + (success ? 'done' : 'fail');
  s.querySelector('svg').innerHTML = success
    ? '<polyline points="20 6 9 17 4 12"/>'
    : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
}

function collapseProcessCard(card, done = true) {
  const title = card.querySelector('.process-title');
  if (title) title.textContent = currentLang === 'en' ? 'Completed' : '处理完成';
  card.classList.add('collapsed');
}

// ── Think block helpers ──
function createThinkBlock() {
  const el = document.createElement('div');
  el.className = 'think-block open';
  el.innerHTML = `<div class="think-header" onclick="this.closest('.think-block').classList.toggle('open')">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    <span class="think-title">${currentLang === 'en' ? 'Thinking…' : '思考中…'}</span>
    <svg class="think-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
  </div>
  <div class="think-body think-streaming"></div>`;
  return el;
}

function finalizeThinkBlock(block) {
  const title = block.querySelector('.think-title');
  if (title) title.textContent = currentLang === 'en' ? 'Thought process' : '思考过程';
  block.querySelector('.think-body').classList.remove('think-streaming');
  block.classList.remove('open'); // 默认收起，用户可展开
}

// ── Send to API (streaming) ──
async function callAPI(msg){
  const t0 = Date.now();
  isLoading = true;
  document.getElementById('mainSend').disabled = true;

  // 立即创建 AI 气泡
  const bubbleEl = appendBubble('ai', '');
  const preEl = bubbleEl.querySelector('.msg-pre');
  const stream = startStream(bubbleEl);

  // 创建 process card
  const procCard = createProcessCard();
  preEl.appendChild(procCard);
  let procStep = 0; // 递增 ID，避免冲突
  let thinkBlock = null;
  let thinkBody = null;
  let thinkAccum = '';
  let firstChunk = true;

  try {
    const res = await apiFetch('/api/chat/stream', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: msg, conv_id: convId, web_search: webSearchEnabled, lang: currentLang, thinking_mode: thinkingEnabled })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
      preEl.remove();
      stream.finish();
      bubbleEl.querySelector('.mbubble').textContent = '抱歉，出了点问题：' + (err.error || `HTTP ${res.status}`);
      return;
    }

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    let lastEvent = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      const lines = buf.split('\n');
      buf = lines.pop();

      for (const line of lines) {
        if (line.startsWith('event: ')) { lastEvent = line.slice(7).trim(); continue; }
        if (line === '') { lastEvent = ''; continue; }
        if (!line.startsWith('data: ')) continue;
        let d;
        try { d = JSON.parse(line.slice(6)); } catch { continue; }

        if (lastEvent === 'status') {
          if (d.type === 'rag') {
            addProcessStep(procCard, 'rag', d.text);
          } else if (d.type === 'rag_done') {
            doneProcessStep(procCard, 'rag', true);
          } else if (d.type === 'tool') {
            const sid = 'tool-' + (++procStep);
            addProcessStep(procCard, sid, toolLabel(d.name));
            procCard._lastToolId = sid;
          } else if (d.type === 'tool_done') {
            if (procCard._lastToolId) doneProcessStep(procCard, procCard._lastToolId, d.success !== false);
          }
        }

        else if (lastEvent === 'thinking') {
          if (!thinkBlock) {
            thinkBlock = createThinkBlock();
            preEl.appendChild(thinkBlock);
            thinkBody = thinkBlock.querySelector('.think-body');
          }
          thinkAccum += d.text;
          thinkBody.textContent = thinkAccum;
          scrollBottom();
        }

        else if (lastEvent === 'think_end') {
          if (thinkBlock) finalizeThinkBlock(thinkBlock);
        }

        else if (lastEvent === 'chunk' || (!lastEvent && d.text)) {
          if (d.text) {
            if (firstChunk) {
              firstChunk = false;
              collapseProcessCard(procCard);
            }
            stream.push(d.text);
          }
        }

        else if (lastEvent === 'done') {
          if (d.convId) {
            convId = d.convId;
            document.getElementById('shareBtn').style.display = '';
          }
          stream.finish();
          _log.event('chat_reply', { ms: Date.now()-t0, convId });
          if (convId) history.replaceState(null, '', '/chat/' + convId);
          loadConvList();
        }

        else if (lastEvent === 'suggestions') {
          if (d.suggestions?.length) renderSuggestions(bubbleEl, d.suggestions);
        }

        else if (lastEvent === 'error') {
          stream.finish();
          bubbleEl.querySelector('.mbubble').textContent = '抱歉，出了点问题：' + (d.message || '未知错误');
        }
      }
    }

  } catch(e) {
    _log.error('callAPI stream error', e.stack, { msg: msg.slice(0,80) });
    stream.finish();
    bubbleEl.querySelector('.mbubble').textContent = '网络错误，请稍后重试。';
  } finally {
    isLoading = false;
    document.getElementById('mainSend').disabled = false;
  }
}

// ── Start chat from landing page ──
async function startChat(msg){
  convId = null;
  document.getElementById('msgsInner').innerHTML = '';
  showChatApp();
  appendBubble('user', msg);
  await callAPI(msg);
}

// ── Quick ask from welcome cards ──
async function quickAsk(msg){
  appendBubble('user', msg);
  await callAPI(msg);
}

// ── Main textarea send ──
// 门店查询拦截：检测关键词，提取地点名
const STORE_RE = /门店|专卖店|体验店|服务站|售后.*店|维修.*点/;
const LOC_RE   = /(.{1,15}?)(?:附近|周边|旁边|那边|这边|的门店|的专卖|的联想)/;

function extractStoreLocation(msg) {
  const m = msg.match(LOC_RE);
  if (!m) return null;
  // 去掉句首的"联想""有没有""查"等虚词
  return m[1].replace(/^(联想|有没有|查一下|查|帮我查|我想找|找|看看|哪里有)\s*/g, '').trim() || null;
}

async function sendMain(directMsg){
  const ta = document.getElementById('mainTa');
  const msg = (typeof directMsg === 'string' ? directMsg : ta.value).trim();
  if (!msg || isLoading) return;
  ta.value = ''; ta.style.height = '';
  document.querySelectorAll('.suggestions').forEach(el => el.remove());

  // ── 门店查询拦截 ──
  if (STORE_RE.test(msg)) {
    const loc = extractStoreLocation(msg);
    if (loc) {
      await findStoresByLocation(msg, loc);
      return;
    } else if (/附近|周边|旁边|我这|我在/.test(msg)) {
      // 提到"附近"但没识别到具体地名 → 走 GPS 定位
      await findNearbyStores();
      return;
    }
    // 否则（只说"门店"没说位置）→ 走普通 AI 问答
  }

  appendBubble('user', msg);
  await callAPI(msg);
}
document.getElementById('mainSend').addEventListener('click', sendMain);
document.getElementById('mainTa').addEventListener('keydown', e => {
  if (e.key==='Enter' && !e.shiftKey){ e.preventDefault(); sendMain(); }
});
document.getElementById('mainTa').addEventListener('input', function(){
  this.style.height = '';
  this.style.height = Math.min(this.scrollHeight, 150) + 'px';
});

// ── Hero input ──
document.getElementById('heroSend').addEventListener('click', () => {
  const v = document.getElementById('heroInput').value.trim();
  if (v) startChat(v);
});
document.getElementById('heroInput').addEventListener('keydown', e => {
  if (e.key==='Enter' && !e.shiftKey){ e.preventDefault(); document.getElementById('heroSend').click(); }
});
// ── Pills 点击事件（内容已在脚本顶部立即渲染）──
document.getElementById('qpills').addEventListener('click', e => {
  const btn = e.target.closest('.qp');
  if(btn) startChat(btn.textContent.trim());
});
document.querySelectorAll('.hcat').forEach(c => {
  c.addEventListener('click', () => { document.querySelectorAll('.hcat').forEach(x=>x.classList.remove('active')); c.classList.add('active'); });
});

// ── Utils ──
function scrollBottom(){ const w=document.getElementById('msgsWrap'); w.scrollTop=w.scrollHeight; }
function escHtml(t){ return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── Copy AI message ──
function copyMsg(btn){
  const text = btn.closest('.msg').querySelector('.mbubble').innerText;
  navigator.clipboard.writeText(text).then(()=>{
    btn.classList.add('copied');
    btn.innerHTML = `<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>已复制`;
    setTimeout(()=>{ btn.classList.remove('copied'); btn.innerHTML=`<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>复制`; }, 1800);
  }).catch(()=>{});
}

// ── Render follow-up suggestions ──
function renderSuggestions(bubbleEl, suggestions) {
  // 移除旧的 suggestions（如果有）
  document.querySelectorAll('.suggestions').forEach(el => el.remove());
  const wrap = document.createElement('div');
  wrap.className = 'suggestions';
  suggestions.forEach(s => {
    const chip = document.createElement('button');
    chip.className = 'suggest-chip';
    chip.textContent = s;
    chip.onclick = () => {
      wrap.remove();
      sendMain(s);
    };
    wrap.appendChild(chip);
  });
  // 插在 bubbleEl（.msg div）之后，保持在 msgsInner 内部，切换对话时会被清除
  bubbleEl.insertAdjacentElement('afterend', wrap);
  scrollBottom();
}

// ── Feedback (thumbs up/down) ──
async function sendFeedback(btn, rating) {
  if (!convId) return;
  const actions = btn.closest('.msg-actions');
  // 清除同一消息之前的选中状态
  actions.querySelectorAll('.fb-like,.fb-dislike').forEach(b => { b.classList.remove('liked','disliked'); });
  btn.classList.add(rating === 1 ? 'liked' : 'disliked');
  try {
    await apiFetch('/api/chat/feedback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ conv_id: convId, rating })
    });
  } catch(e) {}
}

// ── Scroll-to-bottom button ──
(function(){
  const wrap = document.getElementById('msgsWrap');
  const btn = document.getElementById('scrollDownBtn');
  wrap.addEventListener('scroll', ()=>{
    const atBottom = wrap.scrollHeight - wrap.scrollTop - wrap.clientHeight < 80;
    btn.classList.toggle('show', !atBottom);
  });
})();

// ── Scroll reveals ──
const ro = new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');ro.unobserve(e.target);}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('[data-reveal]').forEach(el=>ro.observe(el));

// ── Tab switching ──
document.querySelectorAll('.titem').forEach(tab=>{
  tab.addEventListener('click',()=>{
    const map={all:'tabAll',mfg:'tabMfg',edu:'tabEdu',office:'tabOffice'};
    document.querySelectorAll('.titem').forEach(i=>i.classList.remove('active'));
    tab.classList.add('active');
    document.querySelectorAll('.tcontent').forEach(c=>c.classList.remove('active'));
    const el=document.getElementById(map[tab.dataset.tab]);
    if(el) el.classList.add('active');
  });
});

// ── Carousel dots ──
const pcarousel = document.getElementById('pcarousel');
const pcards = pcarousel.querySelectorAll('.pcard');
const dotsEl = document.getElementById('cdots');
const dc = Math.ceil(pcards.length/2);
for(let i=0;i<dc;i++){
  const d=document.createElement('button');
  d.className='cdot'+(i===0?' active':'');
  d.addEventListener('click',()=>{
    pcards[i*2].scrollIntoView({behavior:'smooth',inline:'start',block:'nearest'});
    document.querySelectorAll('.cdot').forEach(x=>x.classList.remove('active'));
    d.classList.add('active');
  });
  dotsEl.appendChild(d);
}
// 手动滑动同步圆点
pcarousel.addEventListener('scroll',()=>{
  const idx = Math.round(pcarousel.scrollLeft / (pcarousel.scrollWidth / dc));
  document.querySelectorAll('.cdot').forEach((x,i)=>x.classList.toggle('active',i===idx));
},{passive:true});

// ── URL router: restore state on refresh ──
async function restoreFromUrl(){
  const p = location.pathname;
  if (p.startsWith('/chat')){
    const id = p.split('/')[2];
    if (id) {
      await Promise.all([loadConvList(), loadConv(id)]);
    } else {
      await loadConvList();
      openChatFresh();
    }
  }
}
restoreFromUrl();

// ── 按地点名搜门店（地理编码 → 周边搜索） ──
async function findStoresByLocation(origMsg, locName) {
  showChatApp();
  appendBubble('user', origMsg);
  const bubbleEl = appendBubble('ai', '');
  const mbubble = bubbleEl.querySelector('.mbubble');
  mbubble.textContent = `🔍 正在定位"${locName}"…`;

  try {
    const geoRes = await apiFetch(`/api/stores/geocode?address=${encodeURIComponent(locName)}`);
    const geo = await geoRes.json();
    if (geo.error) { mbubble.textContent = geo.error; return; }

    mbubble.textContent = '🏪 正在搜索附近联想门店…';
    const storeRes = await apiFetch(`/api/stores/nearby?lat=${geo.lat}&lng=${geo.lng}`);
    const result = await storeRes.json();
    if (result.error) { mbubble.textContent = result.error; return; }

    renderStoreCards(mbubble, result.stores || [], geo.lat, geo.lng, geo.name);
  } catch (e) {
    mbubble.textContent = '搜索失败，请稍后重试。';
  }
}

// ── 门店查询（GPS 定位 + 百度POI） ──
async function findNearbyStores() {
  showChatApp();
  const userBubble = appendBubble('user', '查询附近联想门店');
  const bubbleEl = appendBubble('ai', '');
  const mbubble = bubbleEl.querySelector('.mbubble');
  mbubble.textContent = '📍 正在获取您的位置…';

  if (!navigator.geolocation) {
    // 降级：走 AI 问答
    userBubble.remove(); bubbleEl.remove();
    await startChat('我想查询附近的联想门店，请问如何找到最近的线下服务中心或体验店？');
    return;
  }

  let position;
  try {
    position = await new Promise((resolve, reject) =>
      navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 20000, enableHighAccuracy: false })
    );
  } catch (err) {
    // 拒绝授权或超时 → 降级走 AI 问答
    userBubble.remove(); bubbleEl.remove();
    await startChat('我想查询附近的联想门店，请问如何找到最近的线下服务中心或体验店？');
    return;
  }

  const { latitude: lat, longitude: lng } = position.coords;
  mbubble.textContent = '🔍 正在搜索附近门店…';

  let result;
  try {
    const res = await apiFetch(`/api/stores/nearby?lat=${lat}&lng=${lng}`);
    result = await res.json();
  } catch (e) {
    mbubble.textContent = '搜索失败，请稍后重试。';
    return;
  }

  if (result.error) {
    mbubble.textContent = result.hint || result.error;
    return;
  }

  const stores = result.stores || [];
  renderStoreCards(mbubble, stores, lat, lng);
}

function distText(m) {
  return m < 1000 ? m + ' m' : (m / 1000).toFixed(1) + ' km';
}

function renderStoreCards(mbubble, stores, userLat, userLng, centerName) {
  if (!stores.length) {
    const loc = centerName ? `"${centerName}"附近` : '20 公里内';
    mbubble.innerHTML = `😔 未找到${loc}的联想门店，建议访问 <a href="https://www.lenovo.com.cn/store/" target="_blank">联想官网门店查询</a>。`;
    return;
  }

  const total = stores.length;
  const INIT_SHOW = 3;

  const wrap = document.createElement('div');
  wrap.className = 'store-wrap';

  const intro = document.createElement('div');
  intro.className = 'store-intro';
  const loc = centerName ? `"${centerName}"附近` : '您附近';
  intro.textContent = `为您找到 ${loc} ${total} 家联想门店：`;
  wrap.appendChild(intro);

  stores.forEach((s, i) => {
    const card = document.createElement('div');
    card.className = 'store-card' + (i >= INIT_SHOW ? ' store-hidden' : '');

    // 百度地图导航（BD09坐标）
    const navUrl = `https://api.map.baidu.com/marker?location=${s.lat},${s.lng}&title=${encodeURIComponent(s.name)}&content=${encodeURIComponent(s.address)}&output=html&coord_type=bd09ll`;

    card.innerHTML = `
      <div class="store-card-top">
        <div class="store-name">${escHtml(s.name)}</div>
        <div class="store-dist">${distText(s.dist)}</div>
      </div>
      <div class="store-addr">${escHtml(s.address || '暂无地址')}</div>
      <div class="store-footer">
        ${s.tel ? `<a class="store-tel" href="tel:${escHtml(s.tel)}"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>${escHtml(s.tel)}</a><span class="store-sep">·</span>` : ''}
        <a class="store-nav" href="${navUrl}" target="_blank"><svg viewBox="0 0 24 24"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>导航</a>
      </div>`;
    wrap.appendChild(card);
  });

  if (total > INIT_SHOW) {
    const btn = document.createElement('button');
    btn.className = 'store-expand-btn';
    btn.innerHTML = `<svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>展开更多（共 ${total} 家）`;
    btn.onclick = function() {
      const hidden = wrap.querySelectorAll('.store-hidden');
      const isExpanded = btn.classList.contains('expanded');
      hidden.forEach(el => el.classList.toggle('store-hidden', isExpanded));
      if (isExpanded) {
        // 收起：重新隐藏 INIT_SHOW 之后的
        wrap.querySelectorAll('.store-card').forEach((el, i) => {
          if (i >= INIT_SHOW) el.classList.add('store-hidden');
        });
        btn.classList.remove('expanded');
        btn.innerHTML = `<svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>展开更多（共 ${total} 家）`;
      } else {
        wrap.querySelectorAll('.store-card').forEach(el => el.classList.remove('store-hidden'));
        btn.classList.add('expanded');
        btn.innerHTML = `<svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>收起`;
      }
      scrollBottom();
    };
    wrap.appendChild(btn);
  }

  mbubble.innerHTML = '';
  mbubble.appendChild(wrap);
  scrollBottom();
}

</script>
</body>
</html>
