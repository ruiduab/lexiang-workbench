  try {
    const data = await apiFetch('/api/chat/conversations').then(r=>r.json());
    convList = data.map(c => ({ id: c.id, title: c.title || c.first_msg || '新对话' }));
    updateSidebar();
  } catch(e){}
}
function updateSidebar(){
  const el = document.getElementById('sbList');
  if (!convList.length){ el.innerHTML = `<div class="conv-empty">${t('noHistory')}</div>`; return; }
  el.innerHTML = convList.map(c => `
    <div class="conv-item ${c.id === convId ? 'active' : ''}" data-cid="${c.id}">
      <svg viewBox="0 0 24 24"><path d="M4 4h16v12H5.17L4 17.17V4z"/></svg>
      <span class="conv-title">${escHtml(c.title.slice(0,28))}</span>
    </div>`).join('');
  el.querySelectorAll('.conv-item').forEach(item => {
    item.addEventListener('click', () => { loadConv(item.dataset.cid); closeSidebar(); });
  });
}
