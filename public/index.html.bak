document.getElementById('chatThemeBtn').addEventListener('click', toggleTheme);

// ── Page transitions ──
function goHome(){
  history.pushState(null, '', '/');
  document.documentElement.classList.remove('is-chat','is-chat-conv');
  document.getElementById('chatApp').classList.remove('active');
  document.getElementById('landingPage').classList.remove('exit');
  closeSidebar();
}
function showChatApp(pushUrl){
  document.documentElement.classList.add('is-chat');
  document.getElementById('landingPage').classList.add('exit');
  document.getElementById('chatApp').classList.add('active');
  setTimeout(() => document.getElementById('mainTa').focus(), 350);
  if (pushUrl !== false) {
    history.pushState(null, '', convId ? '/chat/' + convId : '/chat');
  }
}
window.addEventListener('popstate', () => {
  const p = location.pathname;
  if (p === '/' || p === '') {
    document.getElementById('chatApp').classList.remove('active');
    document.getElementById('landingPage').classList.remove('exit');
  } else if (p.startsWith('/chat')) {
    const id = Number(p.split('/')[2]);
    if (id) loadConv(id);
    else openChatFresh();
  }
});
function openChatFresh(){
  convId = null;
  document.querySelectorAll('.suggestions').forEach(el => el.remove());
  document.getElementById('msgsInner').innerHTML = welcomeHTML();
  updateSidebar();
  updateTitle('联想乐享 · 官方AI助手');
