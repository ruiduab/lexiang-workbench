<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>联想乐享AI-联想官方AI助手-懂你所需更方便-企业超级智能体-企业智能体解决方案</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#fafafa;--fg:#111;--muted:#888;--muted2:#bbb;--accent:#e1002a;
  --card:#fff;--border:rgba(0,0,0,.08);--hover:rgba(0,0,0,.04);
  --sb-bg:#f5f5f5;--sb-hover:rgba(0,0,0,.06);
  --radius:20px;--font-cn:'Noto Sans SC',sans-serif;--font-en:'Outfit',sans-serif;
}
[data-theme="dark"]{
  --bg:#0d0d0d;--fg:#ececec;--muted:#666;--muted2:#444;--accent:#e1002a;
  --card:#1a1a1a;--border:rgba(255,255,255,.07);--hover:rgba(255,255,255,.04);
  --sb-bg:#111;--sb-hover:rgba(255,255,255,.06);
}
html,body{height:100%;overflow:hidden}
.is-chat #landingPage{display:none!important}
.is-chat #chatApp{opacity:1!important;pointer-events:all!important}
.is-chat-conv #welcomeScreen{display:none!important}
body{font-family:var(--font-cn);background:var(--bg);color:var(--fg);-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}
a{text-decoration:none;color:inherit}
::selection{background:var(--accent);color:#fff}
button{cursor:pointer}

/* ════════════════════════════
   LANDING PAGE
════════════════════════════ */
#landingPage{
  position:fixed;inset:0;z-index:10;
  background:var(--bg);overflow-y:auto;
  transition:opacity .4s ease,transform .4s ease;
}
#landingPage.exit{opacity:0;transform:scale(.97);pointer-events:none}

/* NAV */
.lnav{position:sticky;top:0;z-index:100;background:rgba(250,250,250,.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:background .3s}
[data-theme="dark"] .lnav{background:rgba(13,13,13,.9)}
.lnav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;height:56px;padding:0 32px;gap:20px}
.llogo{font-family:var(--font-en);font-weight:700;font-size:22px;letter-spacing:-1px;cursor:pointer}
.llogo em{font-style:normal;color:var(--accent)}
.lnav-links{display:flex;gap:22px;font-size:13px;color:var(--muted);margin-left:auto}
.lnav-links a{padding:3px 0;transition:color .2s;position:relative}
.lnav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1.5px;background:var(--accent);transition:width .25s}
.lnav-links a:hover{color:var(--fg)}
.lnav-links a:hover::after{width:100%}
.lnav-right{display:flex;align-items:center;gap:8px;margin-left:20px}
.icon-btn{width:32px;height:32px;border-radius:50%;border:1px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;color:var(--fg);transition:all .2s}
.icon-btn:hover{border-color:var(--accent);color:var(--accent)}
.lnav-btn{background:var(--accent);color:#fff;border:none;padding:7px 18px;border-radius:999px;font-size:13px;font-weight:600;font-family:var(--font-cn);transition:transform .2s,box-shadow .2s}
.lnav-btn:hover{transform:scale(1.04);box-shadow:0 4px 16px rgba(225,0,42,.3)}

/* HERO */
.hero{min-height:86vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:72px 32px 48px;position:relative;overflow:hidden}
.hero-mesh{position:absolute;inset:0;pointer-events:none}
.blob{position:absolute;border-radius:50%;filter:blur(90px);opacity:.16;animation:drift 14s ease-in-out infinite alternate}
.blob-1{width:480px;height:480px;background:var(--accent);top:-8%;right:-4%}
.blob-2{width:360px;height:360px;background:#ff6b3d;bottom:8%;left:-4%;animation-delay:-5s}
.blob-3{width:260px;height:260px;background:#667eea;top:35%;right:28%;animation-delay:-10s}
@keyframes drift{0%{transform:translate(0,0) scale(1)}100%{transform:translate(36px,-28px) scale(1.12)}}
.hero-wrap{position:relative;z-index:1;width:100%;max-width:600px}
.hero h1{font-size:clamp(28px,5vw,48px);font-weight:900;line-height:1.15;letter-spacing:-.03em;margin-bottom:28px}
.hero h1 .line{display:block;overflow:hidden}
.hero h1 .line span{display:inline-block;animation:slideUp .75s cubic-bezier(.19,1,.22,1) both}
.hero h1 .line:nth-child(2) span{animation-delay:.1s}
@keyframes slideUp{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}
.grad{background:linear-gradient(135deg,var(--accent),#ff6b3d 48%,#667eea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-size:200%;animation:sg 4s linear infinite}
@keyframes sg{0%{background-position:0%}100%{background-position:200%}}

.hero-cats{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:18px}
.hcat{display:inline-flex;align-items:center;gap:5px;padding:7px 16px;border-radius:999px;border:1px solid var(--border);font-size:13px;font-weight:500;background:var(--card);color:var(--fg);transition:all .2s}
.hcat svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none}
.hcat:hover,.hcat.active{border-color:var(--accent);color:var(--accent)}
.hcat.active{background:var(--fg);color:var(--bg);border-color:var(--fg)}
[data-theme="dark"] .hcat.active{color:var(--bg)}

.hero-input-box{width:100%;border:1.5px solid var(--border);border-radius:14px;background:var(--card);overflow:hidden;transition:border-color .25s,box-shadow .25s;position:relative;margin-bottom:10px}
.hero-input-box:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px rgba(225,0,42,.08)}
.hero-input-box input{width:100%;padding:17px 106px 17px 18px;border:none;font-size:16px;outline:none;font-family:var(--font-cn);background:transparent;color:var(--fg)}
.hero-input-box input::placeholder{color:var(--muted)}
.hero-btns{position:absolute;right:9px;top:50%;transform:translateY(-50%);display:flex;gap:5px}
.hbtn{width:34px;height:34px;border-radius:50%;border:none;display:flex;align-items:center;justify-content:center;transition:all .2s}
.hbtn.mic{background:transparent;color:var(--muted)}
.hbtn.mic:hover{color:var(--accent)}
.hbtn.go{background:var(--accent);color:#fff}
.hbtn.go:hover{transform:scale(1.1)}

.ai-badge{display:inline-flex;align-items:center;gap:4px;padding:4px 11px;border-radius:7px;background:var(--bg);border:1px solid var(--border);font-size:11px;color:var(--muted);margin-bottom:16px}
.ai-badge .sp{color:var(--accent)}

.qpills{display:flex;flex-wrap:wrap;gap:7px;justify-content:center}
.qp{padding:6px 13px;border-radius:999px;font-size:12px;color:var(--muted);background:var(--card);border:1px solid var(--border);transition:all .2s;white-space:nowrap}
.qp:hover{color:var(--fg);border-color:var(--accent);transform:translateY(-1px)}

.hero-divider{width:100%;max-width:1200px;height:1px;background:var(--border);margin:44px auto 0}

/* TICKER */
.ticker-wrap{overflow:hidden;padding:16px 0;border-bottom:1px solid var(--border)}
.ticker{display:flex;gap:44px;animation:scroll 28s linear infinite;width:max-content}
.ticker span{font-size:12px;color:var(--muted);white-space:nowrap;font-family:var(--font-en);display:flex;align-items:center;gap:7px}
.ticker span::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--accent)}
@keyframes scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* SECTIONS */
.lsec{padding:80px 32px;max-width:1200px;margin:0 auto}
.slabel{font-family:var(--font-en);font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--accent);font-weight:600;margin-bottom:5px}
.stitle{font-size:32px;font-weight:800;letter-spacing:-.03em;margin-bottom:36px}
.slink{font-size:13px;color:var(--muted);float:right;margin-top:-30px;transition:color .2s}
.slink:hover{color:var(--accent)}

/* CAROUSEL */
.pcarousel{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding:4px 0 18px;scrollbar-width:none}
.pcarousel::-webkit-scrollbar{display:none}
.pcard{min-width:250px;scroll-snap-align:start;background:var(--card);border-radius:18px;border:1px solid var(--border);padding:26px 20px;text-align:center;transition:all .3s cubic-bezier(.19,1,.22,1);flex-shrink:0;position:relative;overflow:hidden}
.pcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--accent),#ff6b3d);transform:scaleX(0);transition:transform .3s;transform-origin:left}
.pcard:hover::after{transform:scaleX(1)}
.pcard:hover{transform:translateY(-6px);box-shadow:0 18px 44px rgba(0,0,0,.07);border-color:transparent}
.pcard-img{width:110px;height:110px;margin:0 auto 16px;border-radius:16px;background:var(--bg);display:flex;align-items:center;justify-content:center;transition:transform .3s}
.pcard:hover .pcard-img{transform:scale(1.06) rotate(-2deg)}
.pcard-img svg{width:48px;height:48px;stroke:var(--fg);stroke-width:1.2;fill:none}
.pcard h4{font-size:14px;font-weight:700;margin-bottom:4px}
.pcard .pdesc{font-size:11px;color:var(--muted);margin-bottom:10px}
.pcard .pprice{font-size:18px;font-weight:800;color:var(--accent);font-family:var(--font-en)}
.cdots{display:flex;gap:6px;justify-content:center;margin-top:10px}
.cdot{width:6px;height:6px;border-radius:50%;background:var(--border);border:none;transition:all .2s}
.cdot.active{width:20px;border-radius:3px;background:var(--accent)}

/* TABS */
.tabrow{display:flex;gap:3px;background:var(--card);border:1px solid var(--border);border-radius:999px;padding:3px;width:fit-content;margin-bottom:28px}
.titem{padding:8px 20px;border-radius:999px;font-size:13px;font-weight:500;border:none;background:transparent;color:var(--muted);font-family:var(--font-cn);transition:all .2s}
.titem.active{background:var(--fg);color:var(--bg)}
.tcontent{display:none;animation:fin .4s ease}
.tcontent.active{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@keyframes fin{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.scard{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:28px;position:relative;overflow:hidden;transition:all .3s cubic-bezier(.19,1,.22,1)}
.scard:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 12px 36px rgba(225,0,42,.06)}
.snum{font-family:var(--font-en);font-size:40px;font-weight:800;color:var(--accent);opacity:.1;position:absolute;top:12px;right:18px;line-height:1}
.scard h4{font-size:16px;font-weight:700;margin-bottom:7px}
.scard p{font-size:12px;color:var(--muted);line-height:1.7}
.sarrow{display:inline-flex;align-items:center;gap:3px;margin-top:12px;font-size:12px;color:var(--accent);font-weight:500;transition:gap .2s}
.scard:hover .sarrow{gap:7px}

/* CASES */
.cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.ccard{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden;transition:all .3s cubic-bezier(.19,1,.22,1)}
.ccard:hover{transform:translateY(-4px);box-shadow:0 18px 48px rgba(0,0,0,.08);border-color:transparent}
.chero{width:100%;height:200px;position:relative;overflow:hidden}
.chbg{width:100%;height:100%;transition:transform .5s;background-size:cover;background-position:center}
.ccard:hover .chbg{transform:scale(1.06)}
.cgrad{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7),transparent 55%)}
.ctxt{position:absolute;bottom:0;left:0;right:0;padding:18px;color:#fff}
.ctxt h4{font-size:14px;font-weight:600;line-height:1.4;margin-bottom:2px}
.ctxt span{font-size:11px;opacity:.7}

/* NEWS */
.timeline{position:relative;padding-left:24px}
.timeline::before{content:'';position:absolute;left:5px;top:7px;bottom:7px;width:1px;background:var(--border)}
.tl{position:relative;padding:0 0 32px 20px}
.tl:last-child{padding-bottom:0}
.tl::before{content:'';position:absolute;left:-20px;top:6px;width:7px;height:7px;border-radius:50%;background:var(--border);transition:all .25s;z-index:1}
.tl:hover::before{background:var(--accent);box-shadow:0 0 0 3px rgba(225,0,42,.12)}
.tdate{font-family:var(--font-en);font-size:11px;color:var(--muted);margin-bottom:4px}
.tl h4{font-size:15px;font-weight:600;margin-bottom:4px;transition:color .2s}
.tl:hover h4{color:var(--accent)}
.tl p{font-size:12px;color:var(--muted);line-height:1.6}

/* CTA */
.ctabanner{border-radius:var(--radius);background:linear-gradient(135deg,#111,#1a1a2e);padding:64px 48px;text-align:center;color:#fff;position:relative;overflow:hidden}
.ctaglow{position:absolute;width:350px;height:350px;border-radius:50%;background:var(--accent);filter:blur(110px);opacity:.1;top:50%;left:50%;transform:translate(-50%,-50%)}
.ctabanner h2{font-size:clamp(24px,4vw,40px);font-weight:900;letter-spacing:-.03em;margin-bottom:10px;position:relative}
.ctabanner p{font-size:14px;opacity:.55;margin-bottom:24px;position:relative}
.ctabanner button{background:#fff;color:#111;padding:12px 32px;border-radius:999px;font-size:14px;font-weight:600;border:none;font-family:var(--font-cn);position:relative;transition:all .25s}
.ctabanner button:hover{transform:scale(1.04);box-shadow:0 6px 24px rgba(255,255,255,.16)}

/* FOOTER */
.lfooter{border-top:1px solid var(--border);padding:44px 32px 28px;max-width:1200px;margin:0 auto}
.ftgrid{display:grid;grid-template-columns:2fr repeat(3,1fr);gap:40px;margin-bottom:32px}
.ftbrand{font-family:var(--font-en);font-size:20px;font-weight:700;margin-bottom:8px}
.ftbrand em{font-style:normal;color:var(--accent)}
.fttag{font-size:12px;color:var(--muted);line-height:1.6}
.ftcol h5{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;color:var(--muted)}
.ftcol a{display:block;font-size:12px;color:var(--fg);opacity:.6;margin-bottom:8px;transition:all .2s}
.ftcol a:hover{color:var(--accent);opacity:1}
.ftbot{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);padding-top:18px;border-top:1px solid var(--border)}

[data-reveal]{opacity:0;transform:translateY(24px);transition:opacity .6s cubic-bezier(.19,1,.22,1),transform .6s cubic-bezier(.19,1,.22,1)}
[data-reveal].vis{opacity:1;transform:translateY(0)}
[data-reveal][data-d="1"]{transition-delay:.1s}
[data-reveal][data-d="2"]{transition-delay:.2s}

@media(max-width:900px){
  .lnav-links{display:none!important}
  .tcontent.active{grid-template-columns:1fr}
  .cgrid{grid-template-columns:1fr}
  .ftgrid{grid-template-columns:1fr 1fr}
  .lsec{padding:56px 20px}
  .hero{padding:88px 20px 44px}
  .ctabanner{padding:44px 24px}
}

/* ════════════════════════════
   LANDING: 移动端汉堡菜单
════════════════════════════ */
.lnav-ham{
  display:none;flex-direction:column;justify-content:center;gap:5px;
  width:36px;height:36px;padding:7px;border:none;background:transparent;
  cursor:pointer;margin-left:8px;border-radius:8px;flex-shrink:0;
}
.lnav-ham span{
  display:block;width:100%;height:2px;background:var(--fg);
  border-radius:2px;transition:all .3s ease;transform-origin:center;
}
.lnav-ham.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.lnav-ham.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.lnav-ham.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.lnav-mob{
  display:none;flex-direction:column;
  background:var(--card);border-top:1px solid var(--border);
  padding:10px 16px 16px;gap:2px;
}
.lnav-mob.open{display:flex}
.lnav-mob a{
  display:block;padding:11px 10px;font-size:14px;color:var(--fg);
  border-radius:9px;transition:all .2s;font-weight:500;
}
.lnav-mob a:hover{color:var(--accent);background:var(--hover)}

/* ════════════════════════════
   CHAT: 侧栏遮罩 & 汉堡按钮
════════════════════════════ */
.sb-overlay{
  position:fixed;inset:0;
  background:rgba(0,0,0,.45);
  z-index:19;
  opacity:0;pointer-events:none;
  transition:opacity .3s ease;
  -webkit-backdrop-filter:blur(3px);
  backdrop-filter:blur(3px);
}
.sb-overlay.active{opacity:1;pointer-events:all}

.menu-btn{
  display:none;
  align-items:center;justify-content:center;
  width:36px;height:36px;
  border-radius:9px;border:1px solid var(--border);
  background:transparent;color:var(--fg);
  margin-right:10px;flex-shrink:0;transition:all .2s;
}
.menu-btn:hover{border-color:var(--accent);color:var(--accent)}
.menu-btn svg{width:16px;height:16px;stroke:currentColor;stroke-width:2;fill:none}

/* ════════════════════════════
   全面移动端适配 (≤768px)
════════════════════════════ */
@media(max-width:768px){
  /* 首页 */
  .lnav-inner{padding:0 14px;gap:8px}
  .lnav-ham{display:flex}
  .lnav-right .lnav-btn{padding:6px 14px;font-size:12px}
  .hero{padding:72px 16px 36px}
  .hero h1{font-size:clamp(22px,7vw,34px)}
  .hero-cats{gap:5px}
  .hcat{padding:6px 12px;font-size:12px}
  .hero-input-box input{padding:14px 100px 14px 14px;font-size:16px}
  .lsec{padding:40px 16px}
  .stitle{font-size:24px}
  .ctabanner{padding:36px 20px}
  .ctabanner h2{font-size:clamp(20px,5vw,28px)}
  .ftgrid{grid-template-columns:1fr 1fr;gap:24px}
  .cgrid{grid-template-columns:1fr}
  .tcontent.active{grid-template-columns:1fr}

  /* Chat 侧栏：off-canvas 抽屉 */
  #chatApp .sidebar{
    position:fixed;
    left:0;top:0;bottom:0;
    z-index:20;
    transform:translateX(-100%);
    transition:transform .3s cubic-bezier(.19,1,.22,1);
    box-shadow:6px 0 32px rgba(0,0,0,.18);
  }
  #chatApp .sidebar.open{transform:translateX(0)}

  /* Chat 主区域铺满 */
  .chat-main{width:100%}
  .menu-btn{display:flex}

  /* 消息区域间距 */
  .msgs-inner{padding:0 12px}
  .welcome{padding:24px 12px}
  .wgrid{grid-template-columns:1fr}
  .welcome h2{font-size:22px}

  /* 输入栏 */
  .input-bar{padding:8px 10px 10px}
  .input-inner{gap:6px}
  .input-tools{padding:0 0 4px}
  .tool-toggle{font-size:10px;padding:2px 7px}
  .chat-topbar{padding:0 14px}
}

/* ════════════════════════════
   CHAT APP
════════════════════════════ */
#chatApp{
  position:fixed;top:0;left:0;right:0;z-index:20;
  height:100vh;height:100dvh;
  display:flex;
  overflow:hidden;
  opacity:0;pointer-events:none;
  transition:opacity .35s ease;
}
#chatApp.active{opacity:1;pointer-events:all}

/* Sidebar */
.sidebar{width:256px;flex-shrink:0;background:var(--sb-bg);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:background .3s}
.sb-header{padding:14px 12px 10px;border-bottom:1px solid var(--border)}
.sb-logo{font-family:var(--font-en);font-weight:700;font-size:18px;letter-spacing:-0.5px;padding:4px 6px;margin-bottom:8px;cursor:pointer}
.sb-logo em{font-style:normal;color:var(--accent)}
.new-btn{width:100%;display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--fg);font-size:13px;font-family:var(--font-cn);transition:all .2s}
.new-btn:hover{background:var(--hover);border-color:var(--accent)}
.new-btn svg{width:15px;height:15px;stroke:currentColor;stroke-width:2;fill:none;opacity:.7}
.sb-section{padding:14px 12px 6px;font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px}
.sb-list{flex:1;overflow-y:auto;padding:4px 8px 12px}
.sb-list::-webkit-scrollbar{width:3px}
.sb-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.conv-item{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:9px;cursor:pointer;transition:background .15s;font-size:13px;color:var(--muted)}
.conv-item:hover{background:var(--sb-hover);color:var(--fg)}
.conv-item.active{background:var(--hover);color:var(--fg)}
.conv-item svg{width:14px;height:14px;stroke:currentColor;stroke-width:1.8;fill:none;flex-shrink:0;opacity:.6}
.conv-title{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.conv-empty{padding:20px 10px;font-size:12px;color:var(--muted2);text-align:center}
.sb-footer{padding:12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:8px}
.sb-theme-btn{display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:9px;border:none;background:transparent;color:var(--muted);font-size:12px;font-family:var(--font-cn);cursor:pointer;transition:all .2s;flex:1}
.sb-theme-btn:hover{background:var(--sb-hover);color:var(--fg)}
.sb-theme-btn svg{width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none}
.back-home-btn{display:flex;align-items:center;gap:6px;padding:8px 10px;border-radius:9px;border:none;background:transparent;color:var(--muted);font-size:12px;font-family:var(--font-cn);cursor:pointer;transition:all .2s}
.back-home-btn:hover{background:var(--sb-hover);color:var(--fg)}
.back-home-btn svg{width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none}

/* Main chat area */
.chat-main{flex:1;display:flex;flex-direction:column;min-width:0;position:relative}
.chat-topbar{height:52px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px 0 24px;flex-shrink:0;gap:8px}
.chat-title{font-size:14px;font-weight:600;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.topbar-btn{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;border:1px solid var(--border);background:none;color:var(--muted);font-size:11px;cursor:pointer;transition:all .15s;font-family:var(--font-cn);white-space:nowrap}
.topbar-btn:hover{border-color:var(--accent);color:var(--accent)}
.topbar-btn.active{border-color:var(--accent);background:color-mix(in srgb,var(--accent) 10%,transparent);color:var(--accent)}
/* suggestions chips */
.suggestions{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;margin-left:42px}
.suggest-chip{display:inline-flex;align-items:center;padding:5px 12px;border-radius:16px;border:1px solid var(--border);background:var(--card);color:var(--muted);font-size:12px;cursor:pointer;transition:all .15s;font-family:var(--font-cn);text-align:left;line-height:1.4}
.suggest-chip:hover{border-color:var(--accent);color:var(--accent);background:color-mix(in srgb,var(--accent) 8%,transparent)}

/* Messages */
.msgs-wrap{flex:1;overflow-y:auto;overflow-x:hidden;padding:28px 0}
.msgs-wrap::-webkit-scrollbar{width:4px}
.msgs-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.msgs-inner{max-width:680px;margin:0 auto;padding:0 24px;display:flex;flex-direction:column;gap:18px}

/* Welcome screen */
.welcome{max-width:680px;margin:0 auto;padding:48px 24px 32px;text-align:center}
.welcome h2{font-size:clamp(22px,4vw,32px);font-weight:900;margin-bottom:10px;letter-spacing:-.03em;line-height:1.2}
.welcome h2 em{font-style:normal}
.welcome p{font-size:14px;color:var(--muted);margin-bottom:28px;line-height:1.7}
.wgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;text-align:left;margin-bottom:0}
.wcard{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;cursor:pointer;transition:all .2s;font-size:13px;line-height:1.5;position:relative;overflow:hidden}
.wcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--accent),#ff6b3d);transform:scaleX(0);transition:transform .25s;transform-origin:left}
.wcard:hover{border-color:var(--accent);transform:translateY(-1px);box-shadow:0 4px 16px rgba(0,0,0,.08)}
.wcard:hover::after{transform:scaleX(1)}
.wcard strong{display:block;font-size:11px;color:var(--accent);margin-bottom:5px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}

/* Msg bubbles */
.msg{display:flex;gap:10px;animation:min .25s ease}
@keyframes min{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.mavatar{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}
.msg.ai .mavatar{background:linear-gradient(135deg,var(--accent),#ff6b3d);color:#fff}
.msg.user .mavatar{background:var(--fg);color:var(--bg);font-size:11px}
.mbubble{max-width:82%;padding:12px 16px;border-radius:16px;font-size:14px;line-height:1.8;word-break:break-word;overflow-wrap:anywhere;min-width:0}
.msg.ai .mbubble{background:var(--card);border:1px solid var(--border);border-bottom-left-radius:4px}
.msg.user .mbubble{background:var(--fg);color:var(--bg);border-bottom-right-radius:4px}
.msg.ai .mbubble pre{font-size:13px;background:rgba(0,0,0,.05);padding:10px;border-radius:8px;overflow-x:auto;margin:8px 0;white-space:pre-wrap}
[data-theme="dark"] .msg.ai .mbubble pre{background:rgba(255,255,255,.05)}
.msg.ai .mbubble p{margin:0 0 8px}
.msg.ai .mbubble p:last-child{margin-bottom:0}
.msg.ai .mbubble h1,.msg.ai .mbubble h2,.msg.ai .mbubble h3{font-size:15px;font-weight:700;margin:10px 0 4px}
.msg.ai .mbubble ul,.msg.ai .mbubble ol{padding-left:20px;margin:4px 0 8px}
.msg.ai .mbubble li{margin-bottom:3px}
.msg.ai .mbubble code{font-family:monospace;font-size:12px;background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px}
[data-theme="dark"] .msg.ai .mbubble code{background:rgba(255,255,255,.08)}
.msg.ai .mbubble strong{font-weight:700}
.msg.ai .mbubble em{font-style:italic}
.msg.ai .mbubble .table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin:8px 0;border-radius:8px;border:1px solid var(--border)}
.msg.ai .mbubble table{border-collapse:collapse;min-width:100%;font-size:13px}
.msg.ai .mbubble th{padding:8px 14px;text-align:left;background:var(--hover);font-weight:600;white-space:nowrap;border-bottom:1px solid var(--border)}
.msg.ai .mbubble td{padding:7px 14px;text-align:left;min-width:80px;border-bottom:1px solid var(--border);border-top:none}
.msg.ai .mbubble tr:last-child td{border-bottom:none}
.msg.ai .mbubble tr:nth-child(even) td{background:var(--hover)}
/* Cursor blink during streaming */
.streaming::after{content:'▋';display:inline;animation:cursor .6s step-end infinite;color:var(--accent);font-size:12px;vertical-align:middle;margin-left:1px}
@keyframes cursor{0%,100%{opacity:1}50%{opacity:0}}

/* Typing dots */
.typing-dots{display:flex;align-items:center;gap:5px;padding:12px 16px;background:var(--card);border:1px solid var(--border);border-radius:16px;border-bottom-left-radius:4px}
.tdot{width:6px;height:6px;border-radius:50%;background:var(--muted2);animation:td .7s ease-in-out infinite}
.tdot:nth-child(2){animation-delay:.12s}
.tdot:nth-child(3){animation-delay:.24s}
@keyframes td{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-4px);opacity:1}}

/* Input bar */
.input-bar{padding:8px 20px 10px;border-top:1px solid var(--border);flex-shrink:0;background:var(--bg)}
.input-inner{max-width:680px;margin:0 auto;display:flex;gap:8px;align-items:flex-end}
.input-tools{max-width:680px;margin:0 auto;display:flex;align-items:center;gap:5px;padding:0 2px 6px}
.mode-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 13px;border-radius:999px;border:1.5px solid var(--border);background:none;color:var(--muted);font-size:12px;cursor:pointer;transition:all .2s;font-family:var(--font-cn);user-select:none;white-space:nowrap}
.mode-pill svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.mode-pill:hover{border-color:var(--fg);color:var(--fg)}
.mode-pill.active-web{border-color:#2563eb;color:#2563eb;background:rgba(37,99,235,.08)}
.mode-pill.active-think{border-color:#7c3aed;color:#7c3aed;background:rgba(124,58,237,.08)}
[data-theme="dark"] .mode-pill.active-web{border-color:#60a5fa;color:#60a5fa;background:rgba(96,165,250,.1)}
[data-theme="dark"] .mode-pill.active-think{border-color:#a78bfa;color:#a78bfa;background:rgba(167,139,250,.1)}
/* Message body column wrapper */
.msg-body{display:flex;flex-direction:column;flex:1;min-width:0}
.process-card{background:var(--hover);border:1px solid var(--border);border-radius:10px;padding:8px 12px;margin-bottom:8px;font-size:12px}
.process-header{display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none;color:var(--muted)}
.process-header svg{width:13px;height:13px;flex-shrink:0;stroke:currentColor;stroke-width:2;fill:none}
.process-title{flex:1;font-size:12px;font-family:var(--font-cn)}
.process-steps{margin-top:6px;display:flex;flex-direction:column;gap:3px}
.process-step{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--muted);padding:2px 0;font-family:var(--font-cn)}
.process-step svg{width:13px;height:13px;flex-shrink:0;stroke:currentColor;stroke-width:2;fill:none}
.process-step.running svg{animation:spin .8s linear infinite;color:var(--accent)}
.process-step.done svg{color:#22c55e}
.process-step.fail svg{color:#ef4444}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.process-card.collapsed .process-steps{display:none}
.process-card.collapsed{background:none;border-color:transparent;padding:2px 12px}
/* Think block */
.think-block{border:1px solid color-mix(in srgb,#7c3aed 30%,var(--border));border-radius:10px;margin-bottom:8px;overflow:hidden;margin-left:42px}
[data-theme="dark"] .think-block{border-color:color-mix(in srgb,#a78bfa 30%,var(--border))}
.think-header{display:flex;align-items:center;gap:6px;padding:8px 12px;cursor:pointer;user-select:none;background:color-mix(in srgb,#7c3aed 5%,var(--bg));font-size:12px;color:#7c3aed;font-family:var(--font-cn)}
[data-theme="dark"] .think-header{color:#a78bfa;background:color-mix(in srgb,#7c3aed 8%,var(--bg))}
.think-header svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.think-chevron{margin-left:auto;transition:transform .2s}
.think-block.open .think-chevron{transform:rotate(180deg)}
.think-body{padding:8px 12px 10px;font-size:12px;color:var(--muted);line-height:1.7;max-height:240px;overflow-y:auto;display:none;border-top:1px solid color-mix(in srgb,#7c3aed 20%,var(--border));white-space:pre-wrap;font-family:var(--font-cn)}
.think-block.open .think-body{display:block}
.think-streaming::after{content:'▋';animation:cursor .6s step-end infinite;color:#7c3aed}
.ta-wrap{flex:1;border:1.5px solid var(--border);border-radius:12px;background:var(--card);transition:border-color .25s,box-shadow .25s;position:relative}
.ta-wrap:focus-within{border-color:rgba(0,0,0,.25);box-shadow:0 2px 8px rgba(0,0,0,.06)}
[data-theme="dark"] .ta-wrap:focus-within{border-color:rgba(255,255,255,.2);box-shadow:0 2px 8px rgba(0,0,0,.3)}
.ta{width:100%;resize:none;border:none;outline:none;padding:8px 12px;font-size:16px;font-family:var(--font-cn);background:transparent;color:var(--fg);line-height:1.6;max-height:120px;min-height:36px}
.ta::placeholder{color:var(--muted)}
.send-btn{width:40px;height:40px;border-radius:10px;border:none;background:var(--fg);color:var(--bg);display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.send-btn:hover:not(:disabled){transform:scale(1.06);opacity:.85}
.send-btn:disabled{opacity:.35;cursor:not-allowed}
.input-hint{text-align:center;font-size:11px;color:var(--muted2);margin-top:7px;max-width:680px;margin-left:auto;margin-right:auto}

/* iOS safe area */
.input-bar{padding-bottom:max(10px,env(safe-area-inset-bottom))}

/* 消息操作栏 */
.msg-actions{display:flex;align-items:center;gap:2px;margin-top:4px;opacity:0;transition:opacity .15s;height:22px}
.msg.ai:hover .msg-actions,.msg.ai:focus-within .msg-actions{opacity:1}
.act-btn{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:6px;border:none;background:none;color:var(--muted);font-size:11px;cursor:pointer;transition:all .15s;font-family:var(--font-cn)}
.act-btn:hover{background:var(--hover);color:var(--fg)}
.act-btn svg{width:11px;height:11px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.act-btn.copied{color:var(--accent)}
.act-btn.liked{color:#22c55e}
.act-btn.disliked{color:#ef4444}
/* 来源链接样式 */
.msg.ai .mbubble a{color:var(--accent);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .15s}
.msg.ai .mbubble a:hover{border-bottom-color:var(--accent)}

/* 门店卡片 */
.store-wrap{display:flex;flex-direction:column}
.store-intro{font-size:13px;color:var(--muted);margin-bottom:10px;font-family:var(--font-cn);line-height:1.6}
.store-card{border:1px solid var(--border);border-radius:12px;padding:12px 14px;background:var(--card);transition:border-color .2s}
.store-card+.store-card{margin-top:8px}
.store-card:hover{border-color:var(--accent)}
.store-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.store-name{font-size:14px;font-weight:600;color:var(--fg);font-family:var(--font-cn);line-height:1.4}
.store-dist{font-size:12px;font-weight:700;color:var(--accent);white-space:nowrap;flex-shrink:0}
.store-addr{font-size:12px;color:var(--muted);margin-top:4px;font-family:var(--font-cn);line-height:1.5}
.store-footer{display:flex;align-items:center;flex-wrap:wrap;gap:0;margin-top:6px}
.store-tel{display:inline-flex;align-items:center;gap:4px;font-size:11.5px;color:var(--muted);font-family:var(--font-cn);text-decoration:none}
.store-tel svg,.store-nav svg{width:11px;height:11px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.store-sep{color:var(--border);margin:0 8px;font-size:11px}
.store-nav{display:inline-flex;align-items:center;gap:4px;font-size:11.5px;color:var(--accent);cursor:pointer;font-family:var(--font-cn);text-decoration:none}
.store-nav:hover{text-decoration:underline}
.store-expand-btn{display:flex;align-items:center;justify-content:center;gap:5px;margin-top:10px;padding:7px 0;border:1px dashed var(--border);border-radius:10px;background:none;color:var(--muted);font-size:12px;font-family:var(--font-cn);cursor:pointer;width:100%;transition:all .2s}
.store-expand-btn:hover{border-color:var(--accent);color:var(--accent)}
.store-expand-btn svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;transition:transform .2s}
.store-expand-btn.expanded svg{transform:rotate(180deg)}
.store-hidden{display:none}
/* 回到底部按钮 */
.scroll-down-btn{
  position:absolute;bottom:76px;right:16px;
  width:34px;height:34px;border-radius:50%;
  border:1px solid var(--border);background:var(--card);
  color:var(--muted);display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .25s;
  box-shadow:0 2px 10px rgba(0,0,0,.08);
  opacity:0;pointer-events:none;z-index:5;
}
.scroll-down-btn.show{opacity:1;pointer-events:all}
.scroll-down-btn:hover{border-color:var(--accent);color:var(--accent);transform:translateY(1px)}
.scroll-down-btn svg{width:14px;height:14px;stroke:currentColor;stroke-width:2.5;fill:none}

@media(max-width:768px){
  /* 防止 iOS 自动缩放 */
  .ta{font-size:16px}
  .hero-input-box input{font-size:16px}
  /* 回到底部按钮位置适配 */
  .scroll-down-btn{bottom:72px;right:10px}
}
</style>
</head>
<body>
<script>var _p=location.pathname;if(_p.startsWith('/chat')){document.documentElement.classList.add('is-chat');if(_p.split('/')[2])document.documentElement.classList.add('is-chat-conv');}</script>

<!-- ══════════ LANDING PAGE ══════════ -->
<div id="landingPage">

<nav class="lnav">
  <div class="lnav-inner">
    <div class="llogo">Lenovo<em>.</em></div>
    <div class="lnav-links">
      <a href="#products">产品中心</a>
      <a href="#solutions">解决方案</a>
      <a href="#cases">客户案例</a>
      <a href="#news">新闻</a>
    </div>
    <div class="lnav-right">
      <button class="icon-btn" id="landThemeBtn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg></button>
      <button class="lnav-btn" onclick="openChatFresh()">开始对话</button>
    </div>
    <button class="lnav-ham" id="lnavHam" onclick="toggleMobileNav()" aria-label="展开菜单">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="lnav-mob" id="lnavMob">
    <a href="#products" onclick="closeMobileNav()">产品中心</a>
    <a href="#solutions" onclick="closeMobileNav()">解决方案</a>
    <a href="#cases" onclick="closeMobileNav()">客户案例</a>
    <a href="#news" onclick="closeMobileNav()">新闻</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-mesh">
    <div class="blob blob-1"></div><div class="blob blob-2"></div><div class="blob blob-3"></div>
  </div>
  <div class="hero-wrap">
    <h1>
      <div class="line"><span>你好，我是<span class="grad">联想乐享</span></span></div>
    </h1>
    <div class="hero-cats">
      <button class="hcat active" onclick="startChat('我想买一台笔记本电脑，能帮我推荐适合的联想产品吗？')"><svg viewBox="0 0 24 24"><path d="M3 3h18v18H3z"/><path d="M9 3v18M3 9h18"/></svg>商品导购</button>
      <button class="hcat" onclick="startChat('联想有哪些适合企业的解决方案？请介绍一下。')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>解决方案</button>
      <button class="hcat" onclick="findNearbyStores()"><svg viewBox="0 0 24 24"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>门店查询</button>
      <button class="hcat" onclick="startChat('我购买了联想产品，想了解我的质保权益和售后服务，怎么查询？')"><svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7L12 16.4 5.7 21l2.3-7L2 9.4h7.6z"/></svg>我的权益</button>
      <button class="hcat" onclick="startChat('我想联系联想客服，请问有哪些联系方式？电话、在线客服或邮件？')"><svg viewBox="0 0 24 24"><path d="M4 4h16v12H5.17L4 17.17V4z"/></svg>联系我们</button>
    </div>
    <div class="hero-input-box">
      <input id="heroInput" type="text" placeholder="最近有什么优惠活动？" autocomplete="off">
      <div class="hero-btns">
        <button class="hbtn mic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="1" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0014 0"/><line x1="12" y1="17" x2="12" y2="21"/></svg></button>
        <button class="hbtn go" id="heroSend"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg></button>
      </div>
    </div>
    <div class="qpills" id="qpills"></div>
    <script>!function(){var A=['最近有什么优惠活动？','办公用5000元左右怎么选？','Y7000P和R7000P选哪个？','帮我推荐一款ThinkPad','小新Pro 14值得买吗？','拯救者系列有哪些旗舰机型？','联想会员有哪些专属权益？','ThinkBook和ThinkPad有什么区别？','联想有哪些AI PC？','想买游戏本，预算8000怎么选？','联想笔记本售后怎么样？','小新Air和小新Pro区别是什么？','联想一体机推荐','拯救者刃9000K配置怎么样？','联想有哪些轻薄本？','联想和惠普、戴尔哪个好？','ThinkPad X1 Carbon适合商务吗？','联想台式机有哪些推荐？','如何查询联想产品保修？','联想最新旗舰笔记本是哪款？'];var s=A.slice().sort(function(){return Math.random()-.5}).slice(0,5);document.getElementById('qpills').innerHTML=s.map(function(t){return'<button class="qp">'+t+'</button>';}).join('');}();</script>
  </div>
  <div class="hero-divider"></div>
</section>

